# Do not commit real secrets. Create a local .env.local and put fresh keys there.
GEMINI_API_KEYS=your-first-key,your-second-key
GEMINI_PLANNER_MODEL=gemini-3.1-flash-lite-preview
GEMINI_BROWSER_MODEL=gemini-3-flash-preview
GEMINI_CLASSIFIER_MODEL=gemini-3.1-flash-lite-preview
AUTO_SUBMIT=false
AUTO_START_AGENT=false
RUN_INTERVAL_SECONDS=900
MAX_COMPANIES_PER_CYCLE=8
MAX_JOBS_PER_CYCLE=15
MAX_APPLICATIONS_PER_CYCLE=2
BROWSER_HEADLESS=false
BROWSER_CHANNEL=
BROWSER_USER_DATA_DIR=runtime/browser-profile
JOB_TAB_START_URL=https://www.stepstone.de/en/jobs/internship/mechatronics/in-frankfurt-am-main
GMAIL_URL=https://mail.google.com/mail/u/0/#inbox
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Applications
GOOGLE_SERVICE_ACCOUNT_FILE=
